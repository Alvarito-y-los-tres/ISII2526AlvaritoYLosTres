@page "/"
@*Espacio de nombres del cliente generado con NSwag*@
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient pruebaCliente;

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

<br>
<br>


@if (_herramientas == null){
	<p><em>Cargando...</em></p>
}
else foreach(var herramienta in _herramientas)
	{
		@herramienta.Nombre
		<br>
	}



@code {
	private ICollection<HerramientasParaComprarDTO> _herramientas;

	//Se ejecutará al cargarse la página
	protected override async Task OnInitializedAsync()
	{
		_herramientas = await pruebaCliente.GetHerramientaParaComprarAsync(null,null);
	}
}


