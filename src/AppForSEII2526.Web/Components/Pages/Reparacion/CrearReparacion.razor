@page "/Reparacion/CrearReparacion"

@using System.Text.Json
@using AppForSEII2526.Web.API
@using AppForSEII2526.Web.Components.Shared
@inject NavigationManager navigation
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CrearReparacion> logger
@inject ReparacionStateContainer ReparacionState

<h3>CrearReparacion</h3>


@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert" id="ErrorsShown">
        @errorMessage
    </div>
}


<EditForm Model="reparacion" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary />
    </div>

    
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p>Errors: @messageError</p>
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="reparacion.NombreCliente" class="form-control" id="Name" />
                <label for="Name">Nombre* </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="reparacion.ApellidoCliente" class="form-control" id="Surname" />
                <label for="SurName">Apellido* </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputDate @bind-Value="reparacion.FechaEntrega" class="form-control" id="DeliveryAddress" />
                <label for="DeliveryAddress">Fecha Entrega*</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="reparacion.Telefono" class="form-control" id="tlf" />
                <label for="tlf">Telefono (opcional)</label>
            </div>
        </div>
        <div class="row g-2">
            <div class="col-md">
                <div class="form-floating">
                    <InputSelect class="form-select" @bind-Value="@reparacion.MetodoPago" id="PaymentMethod">
                        <option value="-1" default>-- Seleccione método --</option>
                        <option value=1> Paypal</option>
                        <option value=2> Cash</option>
                        <option value="0"> Tarjeta</option>
                    </InputSelect>
                    <label for="PaymentMethod">Metodo de pago*</label>
                </div>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@reparacionButtonDisabled">
                    Crear Reparacion
                </button>
            </div>
        </div>
    </div>

    <h4>Detalles de la Reparacion</h4>
    <p><b>Fecha entrega:</b> @reparacion.FechaEntrega.ToString("dd/MM/yyyy") <b>Hecha por:</b> @reparacion.NombreCliente</p>
    <p>
        <b>Precio total:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="submit" @onclick="ModifyRentalItems" id="ModifyMovies">
            Modificar herramientas
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfRentalItems">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Tiempo Reparacion</th>
                    <th>Descripcion(opcional)</th>
                    <th>Cantidad*</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in reparacion.Items)
                {
                    <tr id="MovieData_@item.NombreHerramienta">
                        <td>@item.NombreHerramienta</td>
                        <td>@item.Precio</td>
                        <td>@ObtenerTiempo(item.NombreHerramienta) dias</td>
                        <td><InputText @bind-Value="item.DescripcionProblema" class="form-control" id="@($"description_{item.NombreHerramienta}")" /></td>
                        <td><InputNumber @bind-Value="item.Cantidad" class="form-control" placeholder="0" id="@($"cantidad_{item.NombreHerramienta}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@if (DialogIsOpen)
{
    <Dialog Caption="Items Reparacion"
            Message="Do you want to proceed to create repareision?"
            OnClose="@OnDialogClose"
            Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string errorMessage = "";
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }

    private CrearReparacionDTO reparacion => ReparacionState.Reparacion;
    private bool DialogIsOpen;

    private bool reparacionButtonDisabled
    {
        get
        {
            if (reparacion.Items == null || reparacion.Items.Count == 0)
            {
                return true;
            }
            bool hayItemsInvalidos = reparacion.Items.Any(item => item.Cantidad == null || item.Cantidad <= 0);
            return hayItemsInvalidos;
        }
    }

    private float ObtenerTiempo(string nombreitem)
    {
        if (ReparacionState.TiemposReparacionAux.TryGetValue(nombreitem, out float tiempo))
        {
            return tiempo;
        }
        return 404;
    }

    private decimal TotalCost
    {
        get
        {
            decimal price = 0;
            if (reparacion.Items != null)
            {
                foreach (var item in reparacion.Items)
                {
                    price += ((int?)item.Cantidad ?? 0) * (decimal)item.Precio;
                }
            }
            return price;
        }
    }

    private void ModifyRentalItems()
    {
        navigation.NavigateTo("/Reparacion/SelectItemReparacion");
    }

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        errorMessage = ""; // Limpiamos errores viejos

        if (isOk)
        {
            try
            {
                var resultado = await apiclient.CrearReparacionAsync(reparacion);

                int nuevoId = 0;
                if (resultado.Items != null && resultado.Items.Count > 0)
                {
                    nuevoId = resultado.Items.First().ReparacionId;
                }

                if (nuevoId > 0)
                {
                    ReparacionState.Reparacion = new CrearReparacionDTO
                    {
                        Items = new List<ReparacionItemDTO>()
                    };
                    ReparacionState.Reparacion.MetodoPago = -1;

                    navigation.NavigateTo($"/Reparacion/DetalleReparacion?ReparacionID={nuevoId}");
                }
                else
                {
                    errorMessage = "Error: La reparación se guardó, pero no se pudo recuperar el ID para redirigir.";
                }
            }
            catch (ApiException ex)
            {
                if (ex.StatusCode == 400)
                {
                    if (ex is ApiException<ValidationProblemDetails> validationEx && validationEx.Result != null)
                    {
                        var errors = validationEx.Result.Errors;
                        if (errors != null && errors.Count > 0)
                        {
                            if (errors.ContainsKey("FechaEntrega"))
                            {
                                errorMessage = errors["FechaEntrega"].First();
                            }
                            else if (errors.ContainsKey("fechaEntrega"))
                            {
                                errorMessage = errors["fechaEntrega"].First();
                            }
                            else if (errors.ContainsKey("Items"))
                            {
                                errorMessage = errors["Items"].First();
                            }
                            else
                            {
                                errorMessage = errors.First().Value.First();
                            }
                        }
                        else
                        {
                            errorMessage = validationEx.Result.Detail ?? validationEx.Result.Title ?? "Error de validación desconocido.";
                        }
                    }
                    else
                    {
                        errorMessage = "Error 400: Datos incorrectos (No se pudo leer el detalle).";
                    }
                }
                else
                {
                    //Leemos el mensaje del servidor para errores como 404 ---
                    if (!string.IsNullOrEmpty(ex.Response))
                    {
                        errorMessage = ex.Response;
                    }
                    else
                    {
                        errorMessage = $"Error del Servidor: {ex.StatusCode}";
                    }
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error inesperado: {ex.Message}";
                logger.LogError($"Excepción: {ex}");
            }
        }
    }
}