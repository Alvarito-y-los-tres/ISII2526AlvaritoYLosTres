@page "/compra/createcompra"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@*using Microsoft.AspNetCore.Authorization*@
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreateCompra> logger
@inject CompraStateContainer compraStateContainer

<h3>Create Compra</h3>

<EditForm Model="compra" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary />
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.NombreCliente" class="form-control" id="Nombre" />
                <label for="Nombre">Nombre </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.ApellidoCliente" class="form-control" id="Apellido" />
                <label for="Apellido">Apellido </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.DireccionEnvio" class="form-control" id="DireccionEnvio" />
                <label for="DireccionEnvio">Direccion Envio</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.NumTelefono" class="form-control" id="NumeroTelefono" />
                <label for="NumeroTelefono">Número de Teléfono</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.CorreoElectronico" class="form-control" id="CorreoElectrónico" />
                <label for="CorreoElectrónico">Correo Electrónico</label>
            </div>
        </div>

    

     
        <div class="col-md">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select" @bind-Value="@compra.MetodoPagoId" id="TiposMetodoPago">
                    <option value="@((int)TiposMetodosPago.TarjetaCredito)">Tarjeta de Crédito</option>
                    <option value="@((int)TiposMetodosPago.Paypal)">PayPal</option>
                    <option value="@((int)TiposMetodosPago.Cash)">Efectivo</option>
                </InputSelect>
                <label for="TiposMetodoPago">Método de Pago</label>
            </div>
        </div>
        </div>

        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he want to proceed to rent the movies*@
                <button class="btn btn-primary" type="submit" id="Submit">
                    Compra tus herramientas
                </button>
            </div>
        </div>
    
        <h4>Detalle de la Compra</h4>
    <p>
        <b>Precio Total:</b> @PrecioTotal €
        <button class="btn btn-outline-primary" type="submit" @onclick="ModifyCompraItems" id="ModifyCompraItems">
			Modificar Compra
            </button>
            </p>
    
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfRentalItems">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Material</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>Descripcion</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in compra.CompraItems)
                {
                    <tr id="HerramientaData_@item.NombreHerramienta">
                        <td>@item.NombreHerramienta</td>
                        <td>@item.MaterialHerrramienta</td>
                        <td><InputNumber @bind-Value="item.Cantidad" class="form-control" id="@($"cantidad_{item.HerramientaId}")" /></td>
                        <td>@item.PrecioHerramienta</td>
                    <td><InputText @bind-Value="item.DescripcionHerramienta" class="form-control" id="@($"description_{item.HerramientaId}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</EditForm>

@if (DialogIsOpen)
{
    <Dialog Caption="Compra herramientas"
    Message="¿Estás seguro de que quieres realizar una compra de las herramientas seleccionadas?"
    OnClose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors {get { return messageError.Length == 0; }}
    private bool DialogIsOpen;
    private object? errors;
    private CrearCompraDTO compra => compraStateContainer.Compra;

    private decimal PrecioTotal
    {
        get
        {
            return compra.CompraItems.Sum(item =>
                (decimal)item.PrecioHerramienta * item.Cantidad
            );
        }
    }


    private void ModifyCompraItems()
    {
        navigation.NavigateTo("/compra/selectherramientasparacomprar");
    }

    private void OpenDialog(){
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        if (isOk)
        {
            if(compra.CompraItems.Count > 0)
            {
                try
                {
                    var comprado = await apiclient.CrearCompraAsync(compra);
                    compraStateContainer.CompraProcessed();
                    navigation.NavigateTo($"/compra/detallecompra/?CompraID={comprado.NombreCLiente}");
                }
                catch(ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {
                    if(apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }
                catch(ApiException ex)
                {

                    messageError = "Error al procesar la compra";
                }
            }

        }
    }
